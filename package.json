{
  "name": "esg-analyzer-addin",
  "version": "1.0.0",
  "description": "Office Add-in Excel — Analyse ESG & Bilan Carbone",
  "scripts": {
    "dev": "webpack serve --mode development",
    "build": "webpack --mode production",
    "start": "office-addin-debugging start manifest.xml --app excel",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "devDependencies": {
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1",
    "copy-webpack-plugin": "^11.0.0",
    "html-webpack-plugin": "^5.5.3",
    "css-loader": "^6.8.1",
    "style-loader": "^3.3.3",
    "office-addin-debugging": "^4.4.0",
    "office-addin-dev-certs": "^1.11.0",
    "office-addin-manifest": "^1.9.0",
    "gh-pages": "^6.1.1"
  },
  "dependencies": {
    "@microsoft/office-js": "^1.1.82"
  }
}
